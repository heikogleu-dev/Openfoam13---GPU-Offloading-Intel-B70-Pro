+/**
+ * Interface for operators whose numerical values can be refreshed in place
+ * while keeping their structure fixed. Used for AMG hierarchy reuse: the
+ * aggregation and prolong/restrict operators are kept, and only the Galerkin
+ * coarse-operator values are recomputed when the system matrix values change
+ * but its sparsity does not (OGL `caching`). Ported from the hpsim Ginkgo 1.11
+ * fork extension to Ginkgo 2.0 (develop).
+ */
+class UpdateMatrixValue {
+public:
+    virtual void update_matrix_value(std::shared_ptr<const gko::LinOp>) = 0;
+
+    virtual ~UpdateMatrixValue() = default;
+};

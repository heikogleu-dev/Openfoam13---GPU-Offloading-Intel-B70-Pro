 namespace Foam {
 
+// Full-float (plan D): gscalar is the *device* value type for the GPU solve
+// (matrix, vectors, CG, Schwarz, MG). It is decoupled from Foam::scalar (the
+// host/OpenFOAM type, double). With -DOGL_GSCALAR_FLOAT the device solve runs in
+// FP32 (halves matrix VRAM); by default gscalar==scalar==double so the build is
+// byte-for-byte the previous double behaviour. Conversion happens only at the
+// host<->device value boundaries (matrix ingestion, vector init/update/copy_back).
+#ifdef OGL_GSCALAR_FLOAT
+using gscalar = float;
+#else
+using gscalar = scalar;
+#endif
+
+// Convert a host buffer of Src values into a gko::array<Dst> on the given
+// executor. For Src==Dst this is a plain copy. Used to feed the double host LDU
+// / fields into the float device buffers (and back) at the ingestion boundary.
+template <class Dst, class Src>
+inline gko::array<Dst> convert_value_array(
+    std::shared_ptr<const gko::Executor> exec, const Src *src, gko::size_type n)
+{
+    gko::array<Dst> out(exec, n);
+    Dst *d = out.get_data();
+    for (gko::size_type i = 0; i < n; ++i) {
+        d[i] = static_cast<Dst>(src[i]);
+    }
+    return out;
+}
+
+// Convert n values from a host buffer of Src into an existing host buffer of Dst.
+template <class Dst, class Src>
+inline void convert_value_buffer(const Src *src, Dst *dst, gko::size_type n)
+{
+    for (gko::size_type i = 0; i < n; ++i) {
+        dst[i] = static_cast<Dst>(src[i]);
+    }
+}

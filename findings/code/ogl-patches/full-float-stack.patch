diff --git a/CMakeLists.txt b/CMakeLists.txt
index be1aa5e..0c2ef82 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -215,6 +215,15 @@ target_link_libraries(
 if(${GINKGO_WITH_OGL_EXTENSIONS})
   target_compile_definitions(OGL PRIVATE GINKGO_WITH_OGL_EXTENSIONS=1)
 endif()
+
+# Full-float (plan D): run the whole GPU pressure solve (matrix + vectors + CG +
+# Schwarz + MG) in FP32 instead of just the preconditioner. Halves the dominant
+# matrix VRAM (fits the 34M mesh on one 32 GB card). gscalar=float when ON,
+# gscalar=double (== previous behaviour) when OFF. See common.hpp.
+option(OGL_FULL_FLOAT "Full-float FP32 device pressure solve (plan D)" OFF)
+if(OGL_FULL_FLOAT)
+  target_compile_definitions(OGL PRIVATE OGL_GSCALAR_FLOAT=1)
+endif()
 if(${GINKGO_BUILD_CUDA})
   find_package(CUDAToolkit REQUIRED)
   target_compile_definitions(OGL PRIVATE GINKGO_BUILD_CUDA=1)
